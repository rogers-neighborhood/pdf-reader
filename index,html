<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PDF Voice Reader Version 3</title>
  <style>
    :root {
      --bg: #f4f1ea;
      --panel: #fffdf8;
      --ink: #2b2a28;
      --muted: #6b665f;
      --border: #d8d1c6;
      --accent: #6d8a96;
      --ok: #2f6f44;
      --warn: #9a6a16;
      --err: #8b2f2f;
      --debug-bg: #f8f4ee;
      --shadow: 0 10px 24px rgba(0,0,0,.08);
      --radius: 16px;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      background: linear-gradient(180deg, #f8f5ef 0%, #efe8dc 100%);
      color: var(--ink);
    }

    .wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 18px;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .header {
      padding: 18px 22px 10px 22px;
      border-bottom: 1px solid #ece5d9;
      background: linear-gradient(180deg, rgba(255,255,255,.95), rgba(248,245,239,.95));
    }

    .title {
      margin: 0 0 6px 0;
      font-size: 28px;
      line-height: 1.1;
    }

    .subtitle {
      margin: 0;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.4;
    }

    .content {
      display: grid;
      grid-template-columns: 360px 1fr;
      gap: 18px;
      padding: 18px;
    }

    .controls, .viewer {
      border: 1px solid var(--border);
      border-radius: 14px;
      background: #fff;
    }

    .controls {
      padding: 16px;
    }

    .viewer {
      min-height: 700px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .section-title {
      margin: 0 0 10px 0;
      font-size: 18px;
    }

    .label {
      display: block;
      font-size: 14px;
      margin: 12px 0 6px 0;
      color: var(--muted);
    }

    input[type="file"], select, input[type="range"], button, textarea {
      width: 100%;
      font: inherit;
    }

    select, button, textarea {
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 12px;
      background: #fff;
      color: var(--ink);
    }

    textarea {
      resize: vertical;
      line-height: 1.45;
    }

    .btn-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 10px;
    }

    .btn-row-3 {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
      margin-top: 10px;
    }

    button {
      cursor: pointer;
      transition: transform .06s ease, background .2s ease;
    }

    button:hover { background: #faf7f1; }
    button:active { transform: translateY(1px); }

    .primary {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    .primary:hover { background: #5e7883; }

    .stat {
      margin-top: 10px;
      padding: 10px 12px;
      background: #fbf9f5;
      border: 1px solid #ebe3d7;
      border-radius: 10px;
      font-size: 13px;
      line-height: 1.4;
    }

    .ok { color: var(--ok); }
    .warn { color: var(--warn); }
    .err { color: var(--err); }

    .viewer-bar {
      padding: 10px 12px;
      border-bottom: 1px solid #ece5d9;
      background: #fbf8f2;
      font-size: 13px;
      color: var(--muted);
    }

    #pdfFrame {
      width: 100%;
      height: 320px;
      border: 0;
      background: #f3efe8;
    }

    #textBox {
      min-height: 220px;
      margin: 0;
      border: 0;
      border-top: 1px solid #ece5d9;
      border-radius: 0;
      padding: 16px;
      background: #fffdf9;
      font-size: 15px;
    }

    #debugBox {
      min-height: 220px;
      margin: 0;
      border: 0;
      border-top: 1px solid #ece5d9;
      border-radius: 0;
      padding: 16px;
      background: var(--debug-bg);
      font-family: Consolas, Monaco, monospace;
      font-size: 12px;
      white-space: pre-wrap;
    }

    .viewer-split-title {
      padding: 8px 12px;
      font-size: 13px;
      color: var(--muted);
      border-top: 1px solid #ece5d9;
      background: #fcfaf6;
    }

    .range-wrap {
      display: grid;
      grid-template-columns: 1fr 70px;
      gap: 10px;
      align-items: center;
    }

    .note {
      margin-top: 12px;
      padding: 10px 12px;
      font-size: 12px;
      line-height: 1.45;
      color: var(--muted);
      background: #fcfaf6;
      border: 1px dashed #d9d1c4;
      border-radius: 10px;
    }

    @media (max-width: 900px) {
      .content {
        grid-template-columns: 1fr;
      }
      #pdfFrame {
        height: 260px;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="panel">
      <div class="header">
        <h1 class="title">PDF Voice Reader Version 3</h1>
        <p class="subtitle">Version 3 removes the CDN dependency. It expects local copies of pdf.min.js and pdf.worker.min.js to be hosted in the same folder as this HTML file.</p>
      </div>

      <div class="content">
        <div class="controls">
          <h2 class="section-title">Reader Controls</h2>

          <label class="label" for="pdfInput">Upload PDF</label>
          <input id="pdfInput" type="file" accept="application/pdf" />

          <label class="label" for="voiceGender">Voice Preference</label>
          <select id="voiceGender">
            <option value="female">Female</option>
            <option value="male">Male</option>
            <option value="auto">Auto Best Match</option>
          </select>

          <label class="label" for="voiceSelect">Available Voice</label>
          <select id="voiceSelect"></select>

          <label class="label" for="rateRange">Reading Speed</label>
          <div class="range-wrap">
            <input id="rateRange" type="range" min="0.6" max="1.6" step="0.05" value="1.0" />
            <div id="rateValue">1.00x</div>
          </div>

          <label class="label" for="pitchRange">Pitch</label>
          <div class="range-wrap">
            <input id="pitchRange" type="range" min="0.7" max="1.4" step="0.05" value="1.0" />
            <div id="pitchValue">1.00</div>
          </div>

          <div class="btn-row">
            <button id="extractBtn" class="primary">Extract Text</button>
            <button id="speakBtn">Read Aloud</button>
          </div>

          <div class="btn-row">
            <button id="refreshVoicesBtn">Refresh Voices</button>
            <button id="demoTextBtn">Load Demo Text</button>
          </div>

          <div class="btn-row">
            <button id="testScriptBtn">Test Script</button>
            <button id="clearDebugBtn">Clear Debug</button>
          </div>

          <div class="btn-row-3">
            <button id="pauseBtn">Pause</button>
            <button id="resumeBtn">Resume</button>
            <button id="stopBtn">Stop</button>
          </div>

          <div class="stat" id="fileInfo">No PDF loaded.</div>
          <div class="stat" id="statusBox">Status: Starting up...</div>
          <div class="stat" id="envInfo">Environment: checking...</div>
          <div class="stat" id="pdfLibInfo">PDF.js: checking...</div>
          <div class="stat" id="voiceInfo">Voices: checking...</div>

          <div class="note">
            Version 3 note: this file no longer pulls PDF.js from a CDN. To make extraction work, host these three files together in the same folder: this HTML file, pdf.min.js, and pdf.worker.min.js. Then embed that hosted HTML page in Google Sites.
          </div>
        </div>

        <div class="viewer">
          <div class="viewer-bar">PDF preview on top. Extracted text in the middle. Debug log at the bottom.</div>
          <iframe id="pdfFrame" title="PDF preview"></iframe>
          <div class="viewer-split-title">Extracted Text</div>
          <textarea id="textBox" placeholder="Extracted text will appear here."></textarea>
          <div class="viewer-split-title">Debug Log</div>
          <textarea id="debugBox" readonly placeholder="Debug messages will appear here."></textarea>
        </div>
      </div>
    </div>
  </div>

  <script>
    const debugBox = document.getElementById('debugBox');
    const pdfInput = document.getElementById('pdfInput');
    const extractBtn = document.getElementById('extractBtn');
    const speakBtn = document.getElementById('speakBtn');
    const pauseBtn = document.getElementById('pauseBtn');
    const resumeBtn = document.getElementById('resumeBtn');
    const stopBtn = document.getElementById('stopBtn');
    const refreshVoicesBtn = document.getElementById('refreshVoicesBtn');
    const demoTextBtn = document.getElementById('demoTextBtn');
    const testScriptBtn = document.getElementById('testScriptBtn');
    const clearDebugBtn = document.getElementById('clearDebugBtn');
    const pdfFrame = document.getElementById('pdfFrame');
    const textBox = document.getElementById('textBox');
    const voiceGender = document.getElementById('voiceGender');
    const voiceSelect = document.getElementById('voiceSelect');
    const rateRange = document.getElementById('rateRange');
    const pitchRange = document.getElementById('pitchRange');
    const rateValue = document.getElementById('rateValue');
    const pitchValue = document.getElementById('pitchValue');
    const fileInfo = document.getElementById('fileInfo');
    const statusBox = document.getElementById('statusBox');
    const envInfo = document.getElementById('envInfo');
    const pdfLibInfo = document.getElementById('pdfLibInfo');
    const voiceInfo = document.getElementById('voiceInfo');

    let pdfArrayBuffer = null;
    let pdfObjectUrl = '';
    let voices = [];
    let voiceLoadAttempts = 0;
    let pdfjsReady = false;

    function logDebug(message, type = 'info') {
      const stamp = new Date().toLocaleTimeString();
      const tag = type.toUpperCase();
      debugBox.value += `[${stamp}] [${tag}] ${message}\n`;
      debugBox.scrollTop = debugBox.scrollHeight;
      console.log(`[PDF DEBUG ${tag}]`, message);
    }

    function setStatus(message, cls = '') {
      statusBox.className = 'stat';
      if (cls) statusBox.classList.add(cls);
      statusBox.textContent = 'Status: ' + message;
      logDebug(message, cls === 'err' ? 'error' : cls === 'warn' ? 'warn' : 'info');
    }

    function setStat(el, label, message, cls = '') {
      el.className = 'stat';
      if (cls) el.classList.add(cls);
      el.textContent = `${label}: ${message}`;
    }

    function updateRangeDisplays() {
      rateValue.textContent = Number(rateRange.value).toFixed(2) + 'x';
      pitchValue.textContent = Number(pitchRange.value).toFixed(2);
    }

    function cleanText(text) {
      return text
        .replace(/-\n/g, '')
        .replace(/\s*\n\s*/g, ' ')
        .replace(/\s{2,}/g, ' ')
        .trim();
    }

    function inspectEnvironment() {
      const inIframe = window.self !== window.top;
      const hasSpeech = !!window.speechSynthesis;
      const hasFileApi = !!(window.File && window.FileReader && window.Blob);
      const hasUrl = !!window.URL;
      const ua = navigator.userAgent;
      setStat(envInfo, 'Environment', `iframe=${inIframe} | speech=${hasSpeech} | fileAPI=${hasFileApi} | URL=${hasUrl}`, hasSpeech && hasFileApi ? 'ok' : 'warn');
      logDebug(`User agent: ${ua}`);
      logDebug(`Environment check: iframe=${inIframe}, speech=${hasSpeech}, fileAPI=${hasFileApi}, URL=${hasUrl}`);
    }

    function splitIntoChunks(text, maxLength) {
      const sentences = text.match(/[^.!?]+[.!?]*/g) || [text];
      const chunks = [];
      let current = '';
      for (const sentence of sentences) {
        if ((current + ' ' + sentence).trim().length <= maxLength) {
          current = (current + ' ' + sentence).trim();
        } else {
          if (current) chunks.push(current);
          if (sentence.length <= maxLength) {
            current = sentence.trim();
          } else {
            let remaining = sentence.trim();
            while (remaining.length > maxLength) {
              chunks.push(remaining.slice(0, maxLength));
              remaining = remaining.slice(maxLength).trim();
            }
            current = remaining;
          }
        }
      }
      if (current) chunks.push(current);
      return chunks;
    }

    function scoreVoice(voice, hints) {
      const text = `${voice.name} ${voice.lang}`.toLowerCase();
      let score = 0;
      hints.forEach(h => { if (text.includes(h)) score += 2; });
      if (voice.default) score += 1;
      if (/en-us/i.test(voice.lang)) score += 1;
      return score;
    }

    function pickVoiceByGender(preference) {
      if (!voices.length) return null;
      const femaleHints = ['zira', 'susan', 'aria', 'jenny', 'samantha', 'victoria', 'female', 'woman', 'ava', 'serena', 'sonia', 'karen', 'moira'];
      const maleHints = ['david', 'mark', 'guy', 'male', 'man', 'brian', 'alex', 'daniel', 'fred', 'george', 'matthew', 'oliver', 'tom', 'james'];
      const englishVoices = voices.filter(v => /^en(-|_)?/i.test(v.lang));
      const pool = englishVoices.length ? englishVoices : voices;
      if (preference === 'female') return pool.slice().sort((a, b) => scoreVoice(b, femaleHints) - scoreVoice(a, femaleHints))[0] || pool[0];
      if (preference === 'male') return pool.slice().sort((a, b) => scoreVoice(b, maleHints) - scoreVoice(a, maleHints))[0] || pool[0];
      return pool.find(v => v.default) || pool[0];
    }

    function populateVoiceList() {
      try {
        voices = window.speechSynthesis ? (window.speechSynthesis.getVoices() || []) : [];
        voiceSelect.innerHTML = '';
        if (!voices.length) {
          const opt = document.createElement('option');
          opt.value = '';
          opt.textContent = 'No voices available';
          voiceSelect.appendChild(opt);
          setStat(voiceInfo, 'Voices', '0 voices found', 'warn');
          logDebug('No voices returned from speechSynthesis.getVoices().', 'warn');
          return;
        }

        voices.forEach((voice, index) => {
          const opt = document.createElement('option');
          opt.value = String(index);
          opt.textContent = `${voice.name} (${voice.lang})${voice.default ? ' [default]' : ''}`;
          voiceSelect.appendChild(opt);
        });

        const preferred = pickVoiceByGender(voiceGender.value);
        if (preferred) {
          const idx = voices.findIndex(v => v.name === preferred.name && v.lang === preferred.lang);
          if (idx >= 0) voiceSelect.value = String(idx);
        }

        setStat(voiceInfo, 'Voices', `${voices.length} voice(s) found`, 'ok');
        logDebug(`Loaded ${voices.length} voice(s).`);
      } catch (err) {
        setStat(voiceInfo, 'Voices', 'voice load error', 'err');
        logDebug(`Voice load error: ${err.message}`, 'error');
      }
    }

    function loadVoicesWithRetry() {
      voiceLoadAttempts += 1;
      populateVoiceList();
      if (!voices.length && voiceLoadAttempts < 10) {
        logDebug(`Voice retry ${voiceLoadAttempts} scheduled.`);
        setTimeout(loadVoicesWithRetry, 500);
      }
    }

    function getChosenVoice() {
      const selectedIndex = parseInt(voiceSelect.value, 10);
      if (!Number.isNaN(selectedIndex) && voices[selectedIndex]) return voices[selectedIndex];
      return pickVoiceByGender(voiceGender.value);
    }

    function speakText() {
      const text = textBox.value.trim();
      if (!text) {
        setStatus('There is no text to read yet.', 'warn');
        return;
      }
      if (!window.speechSynthesis) {
        setStatus('Speech synthesis is not available in this browser.', 'err');
        return;
      }
      if (!voices.length) populateVoiceList();
      if (!voices.length) {
        setStatus('No voices are available in this browser.', 'err');
        return;
      }

      window.speechSynthesis.cancel();
      const chunks = splitIntoChunks(text, 1800);
      const selectedVoice = getChosenVoice();
      let index = 0;

      function speakNextChunk() {
        if (index >= chunks.length) {
          setStatus('Finished reading.', 'ok');
          return;
        }
        const utterance = new SpeechSynthesisUtterance(chunks[index]);
        if (selectedVoice) utterance.voice = selectedVoice;
        utterance.rate = Number(rateRange.value);
        utterance.pitch = Number(pitchRange.value);
        utterance.onstart = () => setStatus(`Reading chunk ${index + 1} of ${chunks.length} using ${selectedVoice ? selectedVoice.name : 'default voice'}.`, 'ok');
        utterance.onend = () => { index += 1; speakNextChunk(); };
        utterance.onerror = (e) => setStatus(`Speech error: ${e.error || 'unknown error'}.`, 'err');
        window.speechSynthesis.speak(utterance);
      }

      speakNextChunk();
    }

    async function loadPdfJs() {
      return new Promise((resolve, reject) => {
        if (window.pdfjsLib) {
          pdfjsReady = true;
          setStat(pdfLibInfo, 'PDF.js', 'already loaded', 'ok');
          logDebug('PDF.js already present on page.');
          resolve();
          return;
        }

        const script = document.createElement('script');
        script.src = './pdf.min.js';
        script.onload = () => {
          if (!window.pdfjsLib) {
            reject(new Error('pdfjsLib missing after local script load'));
            return;
          }
          try {
            window.pdfjsLib.GlobalWorkerOptions.workerSrc = './pdf.worker.min.js';
            pdfjsReady = true;
            setStat(pdfLibInfo, 'PDF.js', 'loaded from local files', 'ok');
            logDebug('PDF.js loaded from local files: ./pdf.min.js and ./pdf.worker.min.js');
            resolve();
          } catch (err) {
            reject(err);
          }
        };
        script.onerror = () => reject(new Error('Local PDF.js file failed to load. Put pdf.min.js and pdf.worker.min.js beside this HTML file.'));
        document.head.appendChild(script);
      });
    }

    async function extractPdfText() {
      if (!pdfArrayBuffer) {
        setStatus('No PDF is loaded yet. Choose a file first.', 'warn');
        return;
      }
      if (!pdfjsReady || !window.pdfjsLib) {
        setStatus('PDF.js is not ready, so extraction cannot start.', 'err');
        return;
      }

      try {
        setStatus('Starting PDF extraction...', 'ok');
        const loadingTask = window.pdfjsLib.getDocument({ data: pdfArrayBuffer.slice(0) });
        const pdf = await loadingTask.promise;
        logDebug(`PDF opened successfully. Pages: ${pdf.numPages}`);
        const pages = [];

        for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
          setStatus(`Extracting page ${pageNum} of ${pdf.numPages}...`, 'ok');
          const page = await pdf.getPage(pageNum);
          const textContent = await page.getTextContent();
          const strings = textContent.items.map(item => item.str);
          logDebug(`Page ${pageNum}: extracted ${strings.length} text items.`);
          pages.push(strings.join(' '));
        }

        const finalText = cleanText(pages.join('\n\n'));
        textBox.value = finalText;
        setStatus(`Extraction finished. ${finalText.length} characters loaded.`, 'ok');
      } catch (err) {
        textBox.value = '';
        setStatus(`PDF extraction failed: ${err.message}`, 'err');
        logDebug(`PDF extraction stack: ${err.stack || 'no stack available'}`, 'error');
      }
    }

    function runScriptTest() {
      setStatus('Script test button clicked successfully.', 'ok');
      logDebug('Manual script test passed. Event listeners are active.');
      inspectEnvironment();
      populateVoiceList();
      if (pdfjsReady) {
        setStat(pdfLibInfo, 'PDF.js', 'ready', 'ok');
      }
    }

    function bindEvents() {
      pdfInput.addEventListener('change', async (event) => {
        try {
          const file = event.target.files && event.target.files[0];
          if (!file) {
            setStatus('File input changed, but no file was found.', 'warn');
            return;
          }

          logDebug(`File selected: ${file.name} | type=${file.type || 'unknown'} | size=${file.size} bytes`);
          if (file.type && file.type !== 'application/pdf') {
            setStatus(`Selected file type is ${file.type}, not a PDF.`, 'warn');
          }

          if (pdfObjectUrl) URL.revokeObjectURL(pdfObjectUrl);
          pdfObjectUrl = URL.createObjectURL(file);
          pdfFrame.src = pdfObjectUrl;
          pdfArrayBuffer = await file.arrayBuffer();
          fileInfo.textContent = `Loaded: ${file.name} | ${(file.size / 1024 / 1024).toFixed(2)} MB`;
          setStatus('PDF file event fired and file buffer loaded. Click Extract Text next.', 'ok');
          logDebug(`ArrayBuffer loaded successfully. Byte length: ${pdfArrayBuffer.byteLength}`);
        } catch (err) {
          fileInfo.textContent = 'No PDF loaded.';
          setStatus(`File load error: ${err.message}`, 'err');
          logDebug(`File load stack: ${err.stack || 'no stack available'}`, 'error');
        }
      });

      extractBtn.addEventListener('click', extractPdfText);
      speakBtn.addEventListener('click', speakText);
      pauseBtn.addEventListener('click', () => {
        if (window.speechSynthesis) {
          window.speechSynthesis.pause();
          setStatus('Speech paused.', 'ok');
        }
      });
      resumeBtn.addEventListener('click', () => {
        if (window.speechSynthesis) {
          window.speechSynthesis.resume();
          setStatus('Speech resumed.', 'ok');
        }
      });
      stopBtn.addEventListener('click', () => {
        if (window.speechSynthesis) {
          window.speechSynthesis.cancel();
          setStatus('Speech stopped.', 'ok');
        }
      });
      refreshVoicesBtn.addEventListener('click', () => {
        voiceLoadAttempts = 0;
        loadVoicesWithRetry();
        setStatus('Refreshing voices...', 'ok');
      });
      demoTextBtn.addEventListener('click', () => {
        textBox.value = 'This is a demo reading sample. If this reads aloud, the speech engine is working and the remaining issue is PDF handling.';
        setStatus('Demo text loaded.', 'ok');
      });
      testScriptBtn.addEventListener('click', runScriptTest);
      clearDebugBtn.addEventListener('click', () => {
        debugBox.value = '';
        logDebug('Debug log cleared.');
      });
      voiceGender.addEventListener('change', populateVoiceList);
      rateRange.addEventListener('input', updateRangeDisplays);
      pitchRange.addEventListener('input', updateRangeDisplays);
      if (window.speechSynthesis) {
        window.speechSynthesis.onvoiceschanged = () => {
          logDebug('onvoiceschanged fired.');
          populateVoiceList();
        };
      }
    }

    window.addEventListener('error', (event) => {
      logDebug(`Window error: ${event.message} at ${event.filename || 'unknown file'}:${event.lineno || 0}`, 'error');
      setStatus(`Runtime error: ${event.message}`, 'err');
    });

    window.addEventListener('unhandledrejection', (event) => {
      const reason = event.reason && event.reason.message ? event.reason.message : String(event.reason);
      logDebug(`Unhandled promise rejection: ${reason}`, 'error');
      setStatus(`Unhandled promise rejection: ${reason}`, 'err');
    });

    async function init() {
      updateRangeDisplays();
      inspectEnvironment();
      bindEvents();
      setStatus('Page initialized. Loading local PDF.js and voices...', 'ok');

      try {
        await loadPdfJs();
      } catch (err) {
        pdfjsReady = false;
        setStat(pdfLibInfo, 'PDF.js', err.message, 'err');
        logDebug(`PDF.js load error: ${err.message}`, 'error');
      }

      voiceLoadAttempts = 0;
      loadVoicesWithRetry();
      setStatus('Ready. Click Test Script, then choose a PDF. If PDF.js still fails, verify local file paths.', 'ok');
    }

    init();
  </script>
</body>
</html>